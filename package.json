{
  "name": "svelte-intersection-observer",
  "version": "1.1.1",
  "license": "MIT",
  "description": "Detect if an element is in the viewport using the Intersection Observer API",
  "author": "Eric Liu (https://github.com/metonym)",
  "type": "module",
  "svelte": "./src/index.js",
  "scripts": {
    "dev": "bun rollup -cw",
    "build": "bun rollup -c",
    "package": "bun scripts/npm-package.ts",
    "test:types": "bun svelte-check --workspace tests --tsgo",
    "test:e2e": "playwright test",
    "lint": "biome check --write .",
    "lint:changed": "biome check --write --changed --since=master --no-errors-on-unmatched ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^2.5.3",
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "^7.0.0-dev.20260703.1",
    "svelte": "3.59.2",
    "svelte-check": "^4.7.1",
    "svelte-readme": "^3.6.3",
    "vite": "^4.5.14"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metonym/svelte-intersection-observer.git"
  },
  "homepage": "https://metonym.github.io/svelte-intersection-observer/",
  "bugs": "https://github.com/metonym/svelte-intersection-observer/issues",
  "keywords": [
    "svelte",
    "svelte component",
    "intersection observer",
    "viewport",
    "lazy-loading",
    "conditional"
  ]
}
